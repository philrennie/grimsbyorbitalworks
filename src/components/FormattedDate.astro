---
interface Props {
  date: Date;
}

const { date } = Astro.props;

// Display date +400 years (in-universe) while keeping real date in datetime attribute
const displayDate = new Date(date);
displayDate.setFullYear(displayDate.getFullYear() + 400);
---

<time datetime={date.toISOString()}>
  {displayDate.toLocaleDateString('en-GB', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  })}
</time>
