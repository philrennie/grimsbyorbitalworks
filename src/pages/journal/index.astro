---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('journal', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="The Journal" description="Build updates, lore drops, reflections, and site news.">
  <section class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-hull-dark mb-2">The Journal</h1>
    <p class="text-plate-grey mb-8">
      Build updates, lore discoveries, occasional reflections, and notes on what's
      happening with the site. The informal log of an ongoing obsession.
    </p>
    <div class="h-0.5 bg-gow-yellow w-16 mb-8"></div>

    {posts.length === 0 ? (
      <p class="text-plate-grey italic">Nothing written yet. But the pen is uncapped.</p>
    ) : (
      <ul class="space-y-6">
        {posts.map((post) => (
          <li>
            <a href={`/journal/${post.id}`} class="group block">
              <p class="text-xs text-plate-grey"><FormattedDate date={post.data.pubDate} /></p>
              <h3 class="text-lg font-semibold text-hull-dark group-hover:text-gow-yellow-dark transition-colors">
                {post.data.title}
              </h3>
              <p class="text-sm text-hull-mid">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
