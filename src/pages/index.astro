---
import BaseLayout from '../layouts/BaseLayout.astro';
import ShipCard from '../components/ShipCard.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

// Get latest content from each collection
const allShips = (await getCollection('ships', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allJournal = (await getCollection('journal', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredShip = allShips.find((s) => s.data.featured) || allShips[0];
const latestJournal = allJournal.slice(0, 3);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <!-- Hero -->
  <section class="bg-hull-dark text-white py-16">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-4xl font-bold mb-4">
        Grimsby Orbital Works
      </h1>
      <p class="text-lg text-seal-light leading-relaxed mb-6">
        Four hundred years of ships, stories, and stubbornness. An enthusiast's
        archive of the company that built half the 'Verse — and fixed most of
        the other half.
      </p>
      <div class="h-0.5 bg-gow-yellow w-24"></div>
    </div>
  </section>

  <!-- Featured ship -->
  {featuredShip && (
    <section class="max-w-3xl mx-auto px-4 py-12">
      <h2 class="text-sm uppercase tracking-wide text-plate-grey mb-4">Featured Ship</h2>
      <ShipCard
        name={featuredShip.data.name}
        description={featuredShip.data.description}
        slug={featuredShip.id}
        status={featuredShip.data.status}
        shipClass={featuredShip.data.shipClass}
      />
    </section>
  )}

  <!-- Latest from the journal -->
  {latestJournal.length > 0 && (
    <section class="max-w-3xl mx-auto px-4 py-12 border-t border-seal-light">
      <h2 class="text-sm uppercase tracking-wide text-plate-grey mb-6">Latest from the Journal</h2>
      <ul class="space-y-4">
        {latestJournal.map((post) => (
          <li>
            <a href={`/journal/${post.id}`} class="group block">
              <p class="text-xs text-plate-grey"><FormattedDate date={post.data.pubDate} /></p>
              <h3 class="text-lg font-semibold text-hull-dark group-hover:text-gow-yellow-dark transition-colors">
                {post.data.title}
              </h3>
              <p class="text-sm text-hull-mid">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
      <a href="/journal" class="inline-block mt-6 text-sm text-gow-yellow-dark hover:underline">
        All journal entries →
      </a>
    </section>
  )}

  <!-- Quick nav to sections -->
  <section class="max-w-3xl mx-auto px-4 py-12 border-t border-seal-light">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <a href="/ships" class="group block border border-seal-light rounded-lg p-6 hover:border-gow-yellow transition-colors">
        <h3 class="font-bold text-hull-dark group-hover:text-gow-yellow-dark transition-colors mb-1">The Ships</h3>
        <p class="text-sm text-plate-grey">Profiles, stories, and build logs for every vessel in the archive.</p>
      </a>
      <a href="/company" class="group block border border-seal-light rounded-lg p-6 hover:border-gow-yellow transition-colors">
        <h3 class="font-bold text-hull-dark group-hover:text-gow-yellow-dark transition-colors mb-1">The Company</h3>
        <p class="text-sm text-plate-grey">Four centuries of history, people, yards, and institutional stubbornness.</p>
      </a>
      <a href="/workshop" class="group block border border-seal-light rounded-lg p-6 hover:border-gow-yellow transition-colors">
        <h3 class="font-bold text-hull-dark group-hover:text-gow-yellow-dark transition-colors mb-1">The Workshop</h3>
        <p class="text-sm text-plate-grey">Model-building techniques, tools, and materials. Learning in public.</p>
      </a>
      <a href="/journal" class="group block border border-seal-light rounded-lg p-6 hover:border-gow-yellow transition-colors">
        <h3 class="font-bold text-hull-dark group-hover:text-gow-yellow-dark transition-colors mb-1">The Journal</h3>
        <p class="text-sm text-plate-grey">Build updates, lore drops, and occasional reflections.</p>
      </a>
    </div>
  </section>
</BaseLayout>
