---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShipCard from '../../components/ShipCard.astro';
import { getCollection } from 'astro:content';

const ships = (await getCollection('ships', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="The Ships" description="Profiles, stories, and build logs for every vessel in the GOW archive.">
  <section class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-hull-dark mb-2">The Ships</h1>
    <p class="text-plate-grey mb-8">
      Every ship in the archive. Each entry brings together the vessel's profile,
      its story, and the build log documenting its recreation in miniature.
    </p>
    <div class="h-0.5 bg-gow-yellow w-16 mb-8"></div>

    {ships.length === 0 ? (
      <p class="text-plate-grey italic">No ships in the archive yet. The first vessel is on the workbench.</p>
    ) : (
      <div class="space-y-4">
        {ships.map((ship) => (
          <ShipCard
            name={ship.data.name}
            description={ship.data.description}
            slug={ship.id}
            status={ship.data.status}
            shipClass={ship.data.shipClass}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
