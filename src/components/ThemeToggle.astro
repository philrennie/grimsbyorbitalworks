<!--
  Dark Mode Toggle — system default, user-overridable.
  Stores preference in localStorage. Reads system preference via prefers-color-scheme.
  Three states: 'light', 'dark', 'system' (default).
-->

<!-- Inline script in <head> to prevent flash of wrong theme -->
<script is:inline>
  (function() {
    const stored = localStorage.getItem('theme');
    if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  })();
</script>

<!-- Toggle button -->
<button
  id="theme-toggle"
  type="button"
  class="p-2 rounded-md text-seal-light hover:text-gow-yellow transition-colors"
  aria-label="Toggle dark mode"
  title="Toggle dark mode"
>
  <!-- Sun icon (shown in dark mode) -->
  <svg id="theme-icon-light" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
  </svg>
  <!-- Moon icon (shown in light mode) -->
  <svg id="theme-icon-dark" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
  </svg>
  <!-- System icon (shown when following system) -->
  <svg id="theme-icon-system" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
  </svg>
</button>

<script>
  function initThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;

    const iconLight = document.getElementById('theme-icon-light');
    const iconDark = document.getElementById('theme-icon-dark');
    const iconSystem = document.getElementById('theme-icon-system');

    function getTheme(): 'light' | 'dark' | 'system' {
      return (localStorage.getItem('theme') as 'light' | 'dark' | 'system') || 'system';
    }

    function getEffectiveTheme(theme: string): 'light' | 'dark' {
      if (theme === 'system') {
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }
      return theme as 'light' | 'dark';
    }

    function applyTheme(theme: string) {
      const effective = getEffectiveTheme(theme);
      document.documentElement.classList.toggle('dark', effective === 'dark');
    }

    function updateIcon(theme: string) {
      if (!iconLight || !iconDark || !iconSystem) return;
      iconLight.classList.add('hidden');
      iconDark.classList.add('hidden');
      iconSystem.classList.add('hidden');

      if (theme === 'system') {
        iconSystem.classList.remove('hidden');
      } else if (theme === 'dark') {
        // In dark mode, show moon icon
        iconDark.classList.remove('hidden');
      } else {
        // In light mode, show sun icon
        iconLight.classList.remove('hidden');
      }
    }

    // Cycle: system → dark → light → system
    btn.addEventListener('click', () => {
      const current = getTheme();
      let next: 'light' | 'dark' | 'system';

      if (current === 'system') {
        next = 'dark';
      } else if (current === 'dark') {
        next = 'light';
      } else {
        next = 'system';
      }

      localStorage.setItem('theme', next);
      applyTheme(next);
      updateIcon(next);
    });

    // Listen for system theme changes
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
      if (getTheme() === 'system') {
        applyTheme('system');
      }
    });

    // Initialise
    const theme = getTheme();
    applyTheme(theme);
    updateIcon(theme);
  }

  document.addEventListener('astro:page-load', initThemeToggle);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initThemeToggle);
  } else {
    initThemeToggle();
  }
</script>
