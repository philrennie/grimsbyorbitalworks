---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('workshop', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="The Workshop" description="Model-building techniques, tools, materials, and lessons learned.">
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-hull-dark dark:text-workshop-white mb-2">The Workshop</h1>
    <p class="text-plate-grey dark:text-seal-light mb-8">
      Techniques learned, tools tested, materials reviewed. The practical side
      of building tiny ships, documented for anyone else going through the same process.
    </p>
    <div class="h-0.5 bg-gow-yellow w-16 mb-8"></div>

    {posts.length === 0 ? (
      <p class="text-plate-grey italic">Workshop's being set up. Content coming once there's something worth documenting.</p>
    ) : (
      <ul class="space-y-4">
        {posts.map((post) => (
          <li>
            <a href={`/workshop/${post.id}`} class="group block border border-seal-light dark:border-hull-light rounded-lg p-5 hover:border-gow-yellow transition-colors bg-white dark:bg-hull-mid">
              <p class="text-xs text-plate-grey"><FormattedDate date={post.data.pubDate} /></p>
              <h3 class="text-lg font-bold text-hull-dark dark:text-workshop-white group-hover:text-gow-yellow-dark transition-colors">
                {post.data.title}
              </h3>
              <p class="text-sm text-hull-mid dark:text-plate-grey">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
