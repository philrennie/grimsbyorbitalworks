---
import { SITE_TITLE, NAV_LINKS } from '../consts';

const currentPath = Astro.url.pathname;
---

<header class="bg-hull-dark text-seal-light">
  <!-- GOW Yellow stripe — the signature -->
  <div class="h-1 bg-gow-yellow"></div>

  <nav class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
    <!-- Site title -->
    <a href="/" class="text-xl font-bold tracking-tight text-white hover:text-gow-yellow transition-colors">
      {SITE_TITLE}
    </a>

    <!-- Navigation -->
    <ul class="flex gap-6 text-sm font-medium">
      {NAV_LINKS.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class:list={[
              'hover:text-gow-yellow transition-colors',
              currentPath.startsWith(href) ? 'text-gow-yellow' : 'text-seal-light',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
